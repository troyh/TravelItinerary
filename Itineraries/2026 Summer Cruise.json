    {
      "day": 1,
      "leg": "Seattle → Victoria, BC",
      "nm": 68.7,
      "hrs": 4.6,
      "overnight": "Oak Bay anchorage or Victoria Harbour",
      "tags": [
        "customs",
        "fuel-optional",
